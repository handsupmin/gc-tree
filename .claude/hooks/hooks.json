{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "gctree __hook --event SessionStart",
            "metadata": {
              "owner": "gctree"
            }
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "gctree __hook --event UserPromptSubmit",
            "metadata": {
              "owner": "gctree"
            },
            "timeout": 10
          }
        ]
      }
    ]
  }
}
